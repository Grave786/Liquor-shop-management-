{
  "version": 2,
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" },
    { "src": "dist/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api(?:/(.*))?$", "dest": "/api/index.ts?path=$1" },
    { "handle": "filesystem" },
    { "src": "^(.*)$", "dest": "/dist/index.html" }
  ]
}
