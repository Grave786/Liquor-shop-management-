{
  "version": 2,
  "builds": [
    { "src": "api/[...path].ts", "use": "@vercel/node" },
    { "src": "api/health.ts", "use": "@vercel/node" },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "^/api/health$", "dest": "/api/health.ts" },
    { "src": "^/api(?:/.*)?$", "dest": "/api/[...path].ts" },
    { "handle": "filesystem" },
    { "src": "^(.*)$", "dest": "/index.html" }
  ]
}
